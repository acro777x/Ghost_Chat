<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0f172a"
    android:paddingBottom="16dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/glass_card_bg" />

    <!-- Message preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1e293b"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_action_sender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#60a5fa"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_action_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#94a3b8"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Emoji Quick-React Bar -->
    <LinearLayout
        android:id="@+id/reaction_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp">

        <TextView android:id="@+id/react_thumbs" style="@style/ReactionEmoji" android:text="👍" />
        <TextView android:id="@+id/react_heart" style="@style/ReactionEmoji" android:text="❤️" />
        <TextView android:id="@+id/react_laugh" style="@style/ReactionEmoji" android:text="😂" />
        <TextView android:id="@+id/react_wow" style="@style/ReactionEmoji" android:text="😮" />
        <TextView android:id="@+id/react_sad" style="@style/ReactionEmoji" android:text="😢" />
        <TextView android:id="@+id/react_fire" style="@style/ReactionEmoji" android:text="🔥" />
    </LinearLayout>

    <!-- Action buttons -->
    <TextView
        android:id="@+id/btn_copy"
        style="@style/ActionSheetButton" />

    <TextView
        android:id="@+id/btn_reply"
        style="@style/ActionSheetButton" />

    <TextView
        android:id="@+id/btn_star"
        style="@style/ActionSheetButton" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1e293b"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <TextView
        android:id="@+id/btn_delete_local"
        style="@style/ActionSheetButton"
        android:textColor="#ef4444" />

    <TextView
        android:id="@+id/btn_delete_everyone"
        style="@style/ActionSheetButton"
        android:textColor="#ef4444" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1e293b"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <TextView
        android:id="@+id/btn_forward"
        style="@style/ActionSheetButton" />
</LinearLayout>
