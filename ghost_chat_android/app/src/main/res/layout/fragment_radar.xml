<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LoRa Tactical Radar"
        android:textColor="@color/accent_blue"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_title"
        android:text="Scanning Mesh Network..."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="8dp" />

    <!-- Radar UI container -->
    <RelativeLayout
        android:id="@+id/rl_radar_container"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_centerInParent="true">

        <!-- Concentric circles -->
        <View
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:background="@drawable/circle_btn_bg"
            android:alpha="0.2"
            android:layout_centerInParent="true" />
            
        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:background="@drawable/circle_btn_bg"
            android:alpha="0.3"
            android:layout_centerInParent="true" />
            
        <View
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/circle_btn_bg"
            android:alpha="0.4"
            android:layout_centerInParent="true" />

        <!-- Crosshairs -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/accent_blue"
            android:alpha="0.3"
            android:layout_centerVertical="true" />
            
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/accent_blue"
            android:alpha="0.3"
            android:layout_centerHorizontal="true" />

        <!-- Center point (Local Node) -->
        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_btn_bg"
            android:backgroundTint="@color/accent_blue"
            android:layout_centerInParent="true" />

        <!-- Radar Sweep Line (we'll animate rotation in code) -->
        <View
            android:id="@+id/v_sweep"
            android:layout_width="160dp"
            android:layout_height="2dp"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@+id/v_center_anchor"
            android:background="@color/accent_blue"
            android:alpha="0.8" />
            
        <View
            android:id="@+id/v_center_anchor"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:layout_centerInParent="true" />

    </RelativeLayout>

    <Button
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Back to Chat"
        android:background="@drawable/btn_gradient"
        android:textColor="@color/white"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp" />

</RelativeLayout>
