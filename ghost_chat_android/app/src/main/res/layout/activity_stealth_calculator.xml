<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e"
    android:padding="8dp">

    <!-- Display -->
    <TextView
        android:id="@+id/tv_calc_display"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:gravity="end|bottom"
        android:text="0"
        android:textColor="#e0e0e0"
        android:textSize="48sp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp"
        android:fontFamily="sans-serif-light" />

    <!-- Button Grid -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btn_clear" style="@style/CalcBtnOp" android:text="C" android:textColor="#ef4444" />
        <Button android:id="@+id/btn_divide" style="@style/CalcBtnOp" android:text="÷" />
        <Button android:id="@+id/btn_multiply" style="@style/CalcBtnOp" android:text="×" />
        <Button android:id="@+id/btn_minus" style="@style/CalcBtnOp" android:text="-" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btn_7" style="@style/CalcBtn" android:text="7" />
        <Button android:id="@+id/btn_8" style="@style/CalcBtn" android:text="8" />
        <Button android:id="@+id/btn_9" style="@style/CalcBtn" android:text="9" />
        <Button android:id="@+id/btn_plus" style="@style/CalcBtnOp" android:text="+" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btn_4" style="@style/CalcBtn" android:text="4" />
        <Button android:id="@+id/btn_5" style="@style/CalcBtn" android:text="5" />
        <Button android:id="@+id/btn_6" style="@style/CalcBtn" android:text="6" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btn_1" style="@style/CalcBtn" android:text="1" />
        <Button android:id="@+id/btn_2" style="@style/CalcBtn" android:text="2" />
        <Button android:id="@+id/btn_3" style="@style/CalcBtn" android:text="3" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btn_0" style="@style/CalcBtn" android:layout_weight="2" android:text="0" />
        <Button android:id="@+id/btn_dot" style="@style/CalcBtn" android:text="." />
        <Button android:id="@+id/btn_equals" style="@style/CalcBtnEq" android:text="=" />
    </LinearLayout>

</LinearLayout>
